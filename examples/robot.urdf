<?xml version="1.0"?>
<!-- New robot — add links/joints, or import meshes from the Assembly panel. -->
<robot name="my_robot">
  <material name="steel"><color rgba="0.62 0.65 0.69 1"/></material>



  <link name="base">
    <visual>
      <geometry><mesh filename="meshes/buddy_jr_2_base-1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="base__col"><color rgba="0.949 0 0 1"/></material>
    </visual>
  </link>



  <link name="shoulder">
    <visual>
      <origin xyz="0 0 0.003" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/buddy_jr_2_shoulder-3.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="shoulder__col"><color rgba="0.949 0 0 1"/></material>
    </visual>
  </link>
                                      <joint name="buddy_jr_2_shoulder_3_joint" type="revolute">
    <parent link="base"/>
    <child link="shoulder"/>
    <origin xyz="-0.01 0 0.005" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>

  <link name="servo_4">
    <visual>
      <origin xyz="-0.0061 0 -0.0061" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/servo-4.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="servo_4__col"><color rgba="0.2784 0.6078 0.9608 1"/></material>
    </visual>
  </link>
          <joint name="servo_4_joint" type="revolute">
    <parent link="shoulder"/>
    <child link="servo_4"/>
    <origin xyz="-0.006 0 0.0433" rpy="0 0 1.5708"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>
  <link name="arm">
    <visual>
      <origin xyz="0.0173 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/buddy_jr_basic_arm-6.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="arm__col"><color rgba="0.9804 0.9882 1 1"/></material>
    </visual>
  </link>
      <joint name="buddy_jr_basic_arm_6_joint" type="fixed">
    <parent link="servo_4"/>
    <child link="arm"/>
    <origin xyz="0 -0.0107 0.0189" rpy="0 -1.5708 1.5708"/>
  </joint>
  <link name="servo_5">
    <visual>
      <origin xyz="-0.0061 0 -0.0061" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/servo-5.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="servo_5__col"><color rgba="0.2784 0.6078 0.9608 1"/></material>
    </visual>
  </link>
        <joint name="servo_5_joint" type="revolute">
    <parent link="arm"/>
    <child link="servo_5"/>
    <origin xyz="0.0607 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>
  <link name="arm_2">
    <visual>
      <origin xyz="0.0173 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/buddy_jr_basic_arm-7.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="arm_2__col"><color rgba="0.9804 0.9882 1 1"/></material>
    </visual>
  </link>
      <joint name="buddy_jr_basic_arm_7_joint" type="fixed">
    <parent link="servo_5"/>
    <child link="arm_2"/>
    <origin xyz="0 -0.0107 0.0189" rpy="0 -1.5708 1.5708"/>
  </joint>
  <link name="servo_6">
    <visual>
      <origin xyz="-0.0061 0 -0.0061" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/servo-6.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="servo_6__col"><color rgba="0.2784 0.6078 0.9608 1"/></material>
    </visual>
  </link>
          <joint name="servo_6_joint" type="revolute">
    <parent link="arm_2"/>
    <child link="servo_6"/>
    <origin xyz="0.0607 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1" velocity="1"/>
  </joint>
  <link name="camera">
    <visual>
      <origin xyz="0 -0.035 -0.0114" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/buddy_jr_camera_holder-1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="camera__col"><color rgba="0.9804 0.9882 1 1"/></material>
    </visual>
  </link>
      <joint name="buddy_jr_camera_holder_1_joint" type="fixed">
    <parent link="servo_6"/>
    <child link="camera"/>
    <origin xyz="0 -0.0083 0.0189" rpy="1.5708 0 -1.5708"/>
  </joint>
</robot>
